<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="tharmesh.app">

    <application
        android:allowBackup="true"
        android:icon="@android:drawable/sym_def_app_icon"
        android:label="@string/app_name"
        android:roundIcon="@android:drawable/sym_def_app_icon"
        android:supportsRtl="true"
        android:theme="@style/Theme.TharMesh">

        <activity android:name="com.tharmesh.ui.status.StatusActivity" />
        <activity android:name="com.tharmesh.ui.groups.GroupsActivity" />
        <activity android:name="com.tharmesh.ui.contacts.ScanQrActivity" />
        <activity android:name="com.tharmesh.ui.contacts.MyQrActivity" />
        <activity android:name="com.tharmesh.ui.contacts.ContactsActivity" />
        <activity android:name="com.tharmesh.ui.chat.ChatActivity" />
        <activity android:name="com.tharmesh.ui.chats.ChatsActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
